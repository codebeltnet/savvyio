{
    "version": "1",
    "environments": [
        {
            "name": "WSL-Ubuntu",
            "type": "wsl",
            "wslDistribution": "Ubuntu-24.04"
        },
        {
            "name": "Docker-Ubuntu (net9)",
            "type": "docker",
            "dockerImage": "codebeltnet/ubuntu-testrunner:9",
            "dockerArgs": "-e AWS__CallerIdentity -e AWS__IAM__AccessKey -e AWS__IAM__SecretKey"
        },
        {
            "name": "Docker-Ubuntu (net10)",
            "type": "docker",
            "dockerImage": "codebeltnet/ubuntu-testrunner:10",
            "dockerArgs": "-e AWS__CallerIdentity -e AWS__IAM__AccessKey -e AWS__IAM__SecretKey"
        }
    ]
}
